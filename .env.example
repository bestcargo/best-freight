# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret for session signing
SESSION_SECRET=change-this-to-a-long-random-secret-at-least-16-chars

# Public app origin used for OAuth callback URL (production)
# Example: https://your-domain.com
APP_ORIGIN=

# Comma-separated list of allowed frontend origins for CORS
# Example: https://your-app.netlify.app,https://admin.your-app.com
ALLOWED_ORIGINS=

# Gemini API key for frontend (Vite)
VITE_GEMINI_API_KEY=

# Backend API base URL used by frontend when deployed
# Example: https://your-api.onrender.com
VITE_API_BASE_URL=
